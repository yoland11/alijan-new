modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["npm", "run", "build"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "NEXTJS_NPM"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["zip"]

[[ports]]
localPort = 3000
externalPort = 80
