{
  "name": "ajn-next-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "typecheck:libs": "tsc --build lib/db lib/api-client-react lib/api-zod",
